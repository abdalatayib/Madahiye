rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - email: string (required)
    //   - bloodType: string (required)
    //   - lastDonationDate: timestamp (optional)
    //   - lastCheckupDate: timestamp (optional)
    //   - status: string (required, enum: active, banned, pending_verification)
    //   - role: string (required, enum: user, admin)
    //   - rating: number (optional)
    //   - gender: string (optional)
    //
    // Collection: requests
    // Document ID: requestId
    // Fields:
    //   - recipientUid: string (required)
    //   - bloodType: string (required)
    //   - hospitalName: string (required)
    //   - location: string (required)
    //   - urgency: string (required)
    //   - status: string (required)
    //   - createdAt: timestamp (required)
    //   - donorUid: string (optional)
    //
    // Collection: donations
    // Document ID: donationId
    // Fields:
    //   - requestId: string (required)
    //   - donorUid: string (required)
    //   - recipientUid: string (required)
    //   - donationDate: timestamp (required)
    //   - recipientConfirmed: bool (optional)
    //   - donorConfirmed: bool (optional)
    //   - status: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "tayib4986@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.email is string &&
             data.bloodType in ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] &&
             data.status in ["active", "banned", "pending_verification"] &&
             data.role in ["user", "admin"];
    }

    function isValidRequest(data) {
      return data.recipientUid is string &&
             data.bloodType in ["A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-"] &&
             data.hospitalName is string && data.hospitalName.size() > 0 &&
             data.status in ["open", "matched", "completed", "cancelled"];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status);
    }

    match /requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRequest(request.resource.data) && request.resource.data.recipientUid == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || request.resource.data.recipientUid == resource.data.recipientUid || request.resource.data.donorUid == request.auth.uid);
    }

    match /donations/{donationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.donorUid == request.auth.uid || resource.data.recipientUid == request.auth.uid);
      allow create: if isAuthenticated() && (request.resource.data.donorUid == request.auth.uid || request.resource.data.recipientUid == request.auth.uid);
      allow update: if isAuthenticated() && (isAdmin() || resource.data.donorUid == request.auth.uid || resource.data.recipientUid == request.auth.uid);
    }

    match /complaints/{complaintId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.reporterUid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.reporterUid == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
